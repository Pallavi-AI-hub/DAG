    "evidence_required": "Airflow task logs, Datadog infrastructure/application metrics, JIRA/Confluence RAG context for known-issue matching",
    "airflow_logs": "Airflow trigger log shows the Trigger process alive but never firing the resume event",
    "datadog_metrics": "Datadog webhook.callbacks_received metric flat-lined to zero while task remained deferred",
