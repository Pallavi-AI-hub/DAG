    "incident_id": "INC-023",
    "dag_id": "RTL_LOG_STUCK",
    "incident_name": "Logistics carrier tracking-webhook listener stuck",
    "category": "Stuck/Hung Job",
    "severity": "Sev-1 (Critical)",
    "description": "Stuck/Hung Job incident on the Logistics pipeline (RTL_LOG_STUCK): logistics carrier tracking-webhook listener stuck.",
    "symptoms": "A task waiting on a carrier webhook callback (deferrable operator) never resumes; the task has been in deferred state for 9 hours.",
    "root_cause": "The carrier's webhook endpoint changed its callback payload structure, so the trigger's payload-matching condition never evaluates true, and there is no fallback polling path.",
    "business_impact": "Shipment status updates frozen for all in-transit orders, causing customer-facing tracking pages to show stale 'in transit' status for 9+ hours.",
    "resolution": "Add a fallback polling task on a trigger_rule=all_failed branch that activates if the deferred sensor exceeds a threshold; fix payload matching for the new carrier schema."
  },
  "expected_rca": {
    "source_row": {
