    "incident_name": "Store Sales end-of-day Postgres lock wait hangs",
    "category": "Stuck/Hung Job",
    "severity": "Sev-1 (Critical)",
    "description": "Stuck/Hung Job incident on the Finance pipeline (RTL_FIN_STUCK): store Sales end-of-day Postgres lock wait hangs.",
    "symptoms": "The end-of-day sales close task has been in a Postgres lock-wait state for 7 hours against a 20-minute typical runtime.",
    "root_cause": "An ad-hoc analyst query against the same table was left open in an idle-in-transaction state, holding an ACCESS SHARE lock that blocks the close task's ACCESS EXCLUSIVE lock request.",
    "business_impact": "Store financial close cannot finalize; finance cannot post daily sales journal entries.",
    "resolution": "Terminate the blocking idle-in-transaction session; add statement_timeout and idle_in_transaction_session_timeout at the database role level."
  },
