    "incident_id": "INC-026",
    "dag_id": "RTL_MKT_STUCK",
    "incident_name": "Returns disposition workflow hangs on a stalled ML endpoint",
    "category": "Stuck/Hung Job",
    "severity": "Sev-2 (High)",
    "description": "Stuck/Hung Job incident on the Marketing pipeline (RTL_MKT_STUCK): returns disposition workflow hangs on a stalled ML endpoint.",
    "symptoms": "The returns-grading task calling an internal ML scoring endpoint has been running 6 hours against a 15-minute baseline.",
    "root_cause": "The ML endpoint's autoscaler scaled to zero replicas during a low-traffic window and the cold-start health check loop entered a retry cycle with no maximum attempt count.",
    "business_impact": "Returns cannot be graded for restock/liquidation, holding inventory value in limbo and delaying refund-eligibility decisions for customers.",
    "resolution": "Manually cycle the ML endpoint's minReplicas to 1; bound the health-check retry loop with a max-attempts + circuit breaker."
  },
  "expected_rca": {
    "source_row": {
      "sheet": "Expected AI RCA",
