    "incident_id": "INC-026",
    "expected_rca_summary": "AI AutoRCA should identify: The ML endpoint's autoscaler scaled to zero replicas during a low-traffic window and the cold-start health check loop entered a retry cycle with no maximum attempt count.",
    "evidence_required": "Airflow task logs, Datadog infrastructure/application metrics, JIRA/Confluence RAG context for known-issue matching",
    "airflow_logs": "Airflow task log shows repeated 'waiting for endpoint ready' messages with no backoff cap",
    "datadog_metrics": "Datadog custom metric ml_endpoint.replica_count shows 0 for the duration of the stall",
    "confidence_score": 0.8,
    "resolution": "Manually cycle the ML endpoint's minReplicas to 1; bound the health-check retry loop with a max-attempts + circuit breaker.",
    "preventive_action": "Set minReplicas >= 1 for any ML endpoint in the critical path of a production DAG, documented in the metadata model's dependency section."
  }
