    "incident_name": "Ecommerce catalog sync fails on schema evolution",
    "category": "Long Running Job Failure",
    "severity": "Sev-1 (High)",
    "description": "Long Running Job Failure incident on the Promotions pipeline (RTL_PRM_LRJF): ecommerce catalog sync fails on schema evolution.",
    "symptoms": "Ecommerce catalog sync to Snowflake fails after 2h30m when a new nested JSON field breaks the Parquet schema on write.",
    "root_cause": "Shopify added a new 'bundle_components' array field to the product payload; the downstream Parquet writer uses a hard-coded schema instead of schema-on-read/evolution-aware writing.",
    "business_impact": "New bundle products invisible on the ecommerce site until the schema issue is resolved, affecting a live promotional bundle launch.",
    "resolution": "Switch the Parquet writer to schema-evolution-aware mode (merge schema); add the new field to the Snowflake external table DDL."
  },
