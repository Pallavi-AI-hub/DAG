    },
    "incident_id": "INC-053",
    "expected_rca_summary": "AI AutoRCA should identify: The OCR model was originally sized/tested against typical invoice image resolutions (150 DPI), but several new vendors submit scans at 600 DPI, roughly quadrupling per-image GPU memory footprint without any corresponding batch-size adjustment.",
    "evidence_required": "Airflow task logs, Datadog infrastructure/application metrics, JIRA/Confluence RAG context for known-issue matching",
    "airflow_logs": "Airflow task failure logs show CUDA out-of-memory errors isolated to specific vendor-tagged sub-batches",
    "datadog_metrics": "Datadog gpu.memory.usage shows periodic spikes to the allocation ceiling correlated with specific high-DPI vendor batches",
    "confidence_score": 0.8,
    "resolution": "Add a pre-processing step that downsamples images above a DPI threshold before OCR inference; dynamically adjust batch size based on detected image resolution.",
    "preventive_action": "Add input-characteristic validation (resolution, file size) as a standard pre-flight check in the architecture template for any GPU/ML-inference-backed task."
  }
