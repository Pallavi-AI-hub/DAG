    "incident_id": "INC-053",
    "dag_id": "RTL_LOG_RES",
    "incident_name": "Suppliers vendor-document OCR GPU exhaustion",
    "category": "Resource Exhaustion",
    "severity": "Sev-2 (Medium)",
    "description": "Resource Exhaustion incident on the Logistics pipeline (RTL_LOG_RES): suppliers vendor-document OCR GPU exhaustion.",
    "symptoms": "GPU memory on the OCR inference worker is regularly exhausted during month-end invoice processing spikes, causing task failures partway through a batch.",
    "root_cause": "The OCR model was originally sized/tested against typical invoice image resolutions (150 DPI), but several new vendors submit scans at 600 DPI, roughly quadrupling per-image GPU memory footprint without any corresponding batch-size adjustment.",
    "business_impact": "Partial OCR batches fail and must be reprocessed, adding processing delay during the already-constrained month-end AP close window.",
    "resolution": "Add a pre-processing step that downsamples images above a DPI threshold before OCR inference; dynamically adjust batch size based on detected image resolution."
  },
  "expected_rca": {
    "source_row": {
      "sheet": "Expected AI RCA",
